{
  "//": "fenrir couche-0 in-session enforcement + security layer. repo-bootstrap MERGES this into the consuming repo's .claude/settings.json and copies hooks/*.py to .claude/hooks/. Project-scoped so it travels with the repo. All hooks are pure Python stdlib — no bun/node/daemon. EXEC form (command + args) is used so there is NO shell: ${PYTHON} is a placeholder that repo-bootstrap replaces with the ABSOLUTE path of a detected Python >=3.9 interpreter at install time, and ${CLAUDE_PROJECT_DIR} is left verbatim for Claude Code to substitute at runtime. Exec form removes the PowerShell/Git-Bash and bare-`python3`-token dependencies, so the enforcement gate fires identically on macOS/Linux/Windows. Bootstrap refuses to bake a <3.9 interpreter rather than ship a crashing gate.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|MultiEdit|NotebookEdit|Read",
        "hooks": [
          {
            "type": "command",
            "command": "${PYTHON}",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/delivery-guard.py"]
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${PYTHON}",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/tracking-guard.py"]
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PYTHON}",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/prompt-guard.py"]
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "WebFetch|WebSearch|mcp__.*(fetch|web|browser|navigate|http)",
        "hooks": [
          {
            "type": "command",
            "command": "${PYTHON}",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/content-scanner.py"]
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${PYTHON}",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/config-audit.py"]
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${PYTHON}",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/branch-plan-check.py"]
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PYTHON}",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/session-context.py"]
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PYTHON}",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/doc-staleness.py"]
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PYTHON}",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/tool-failure-triage.py"]
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PYTHON}",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/session-end.py"]
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "matcher": "main.tf|variables.tf|outputs.tf|versions.tf|providers.tf|terraform.tfvars",
        "hooks": [
          {
            "type": "command",
            "command": "${PYTHON}",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/iac-watch.py"]
          }
        ]
      }
    ]
  }
}
